# ResiQ CRM — Production Environment Variables
# Copy this to .env and fill in your values

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
JWT_SECRET=change-this-to-a-random-64-char-string

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=resiq
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=resiq_crm
# Set automatically by docker-compose — override if using external DB:
# DATABASE_URL=postgresql://resiq:password@localhost:5432/resiq_crm

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-this-redis-password
# Set automatically by docker-compose — override if using external Redis:
# REDIS_URL=redis://:password@localhost:6379

# ─── Twilio SMS ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_WEBHOOK_URL=https://YOUR_DOMAIN.com/api/webhooks/twilio
SMS_RATE_LIMIT_PER_HOUR=10

# ─── Stripe Payments ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google OAuth (Calendar) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=https://YOUR_DOMAIN.com/api/integrations/google/callback

# ─── Email (Gmail SMTP or SMTP relay) ─────────────────────────────────────────
GMAIL_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password

# ─── App URLs ─────────────────────────────────────────────────────────────────
CLIENT_PORTAL_URL=https://YOUR_DOMAIN.com
API_URL=https://YOUR_DOMAIN.com

# ─── Encryption ───────────────────────────────────────────────────────────────
ENCRYPTION_KEY=change-this-32-char-encryption-key
