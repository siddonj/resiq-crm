# =============================================================================
# ResiQ CRM Environment Configuration
# Copy this file to .env and update values for your environment
# =============================================================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://resiq:resiq_dev@localhost:5434/resiq_crm

# JWT Authentication
# Generate a strong secret: `openssl rand -base64 32`
JWT_SECRET=your_jwt_secret_change_in_production_32_chars_min

# Redis (Background Jobs & Caching)
# Required for email sync and workflows to function
REDIS_URL=redis://localhost:6379

# Email Sync Integration (Gmail)
# Get credentials from Google Cloud Console:
# https://console.cloud.google.com › Create Project › Gmail API › OAuth 2.0
GMAIL_CLIENT_ID=your_gmail_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here

# Token Encryption
# Used to encrypt sensitive data (OAuth tokens, API keys) in database
# Generate a 32-character key: `openssl rand -base64 32`
ENCRYPTION_KEY=your_32_character_encryption_key_here

# API URL
# Frontend will use this to call the backend API
API_URL=http://localhost:5000

# Contact Enrichment
# Hunter.io API key for email verification, person lookup, and company domain data
# Get your key at: https://hunter.io/api
HUNTER_API_KEY=your_hunter_api_key_here

# OpenAI (used for AI-powered company intelligence in enrichment worker)
OPENAI_API_KEY=your_openai_api_key_here
